# Tempo
TEMPO_RPC_URL=https://rpc.tempo.xyz
USDC_TEMPO=0x20c000000000000000000000b9537d11c60e8b50
ESCROW_ADDRESS=0x7331A38bAa80aa37d88D893Ad135283c34c40370

# Your wallet address on Tempo - receives MPP service fee payments
SERVICE_WALLET_ADDRESS=0x...

# User: passkey wallet scoped key (for depositing into escrow)
USER_TEMPO_PRIVATE_KEY=0x...

# Solver / relayer: same key, used on both Polygon and Tempo
# - Polygon: buys CTF on Polymarket CLOB, transfers to user
# - Tempo: posts merkle roots, claims from escrow
SOLVER_POLYGON_PRIVATE_KEY=0x...
RELAYER_PRIVATE_KEY=0x...  # same value as SOLVER_POLYGON_PRIVATE_KEY

# Polygon
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com

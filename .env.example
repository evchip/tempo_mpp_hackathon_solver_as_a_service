# Tempo Mainnet
TEMPO_RPC_URL=https://rpc.tempo.xyz
TEMPO_CHAIN_ID=4217

# Agent wallet - receives the Access Key from the user
# Generate: cast wallet new
AGENT_PRIVATE_KEY=0x...
AGENT_ADDRESS=0x...

# Service wallet - receives MPP payments from the agent
SERVICE_WALLET_ADDRESS=0x...

# pathUSD is the native stablecoin on Tempo (predeployed)
# 0x20c0000000000000000000000000000000000000

# Kalshi sandbox
# Sign up at https://kalshi.com, get API credentials
KALSHI_API_KEY=...
KALSHI_API_KEY_ID=...
KALSHI_BASE_URL=https://demo-api.kalshi.co/trade-api/v2

# Anthropic (evaluator service)
ANTHROPIC_API_KEY=sk-ant-...

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
